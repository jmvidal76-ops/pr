<?xml version="1.0" encoding="Windows-1252"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <FullPath>Debug</FullPath>
    <OutputPath>bin\Debug</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>True</OverwriteDatasets>
    <OverwriteDataSources>True</OverwriteDataSources>
    <TargetServerVersion>SSRS2008R2</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>/MES_MSM</TargetReportFolder>
    <TargetDatasetFolder>/MES_MSM/Datasets</TargetDatasetFolder>
    <TargetDatasourceFolder>/MES_MSM/Data_Sources</TargetDatasourceFolder>
    <TargetReportPartFolder>/MES_MSM/Report Parts</TargetReportPartFolder>
    <TargetServerURL>http://10.2.20.201/ReportServer</TargetServerURL>
    <StartItem>INF_ENV_PROD_ANA_2.rdl</StartItem>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'DebugLocal' ">
    <FullPath>DebugLocal</FullPath>
    <OutputPath>bin\DebugLocal</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>False</OverwriteDatasets>
    <OverwriteDataSources>False</OverwriteDataSources>
    <TargetServerVersion>SSRS2008R2</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>Informes</TargetReportFolder>
    <TargetDatasetFolder>Datasets</TargetDatasetFolder>
    <TargetDatasourceFolder>Data Sources</TargetDatasourceFolder>
    <TargetReportPartFolder>Report Parts</TargetReportPartFolder>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <FullPath>Release</FullPath>
    <OutputPath>bin\Release</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>False</OverwriteDatasets>
    <OverwriteDataSources>False</OverwriteDataSources>
    <TargetServerVersion>SSRS2008R2</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>Informes</TargetReportFolder>
    <TargetDatasetFolder>Datasets</TargetDatasetFolder>
    <TargetDatasourceFolder>Data Sources</TargetDatasourceFolder>
    <TargetReportPartFolder>Report Parts</TargetReportPartFolder>
  </PropertyGroup>
  <PropertyGroup>
    <State>$base64$</State>
    <DataSources>@(DataSource)</DataSources>
    <DataSets>@(DataSet)</DataSets>
    <Reports>@(Report)</Reports>
  </PropertyGroup>
  <ItemGroup>
    <DataSet Include="SintesisTurno.rsd" />
  </ItemGroup>
  <ItemGroup>
    <DataSource Include="DS_MES_MSM_Burgos.rds" />
  </ItemGroup>
  <ItemGroup>
    <Report Include="INF_ENV_PROD_ANA_1.rdl" />
    <Report Include="INF_ENV_PROD_ANA_2.rdl" />
    <Report Include="INF_ENV_PROD_ANA_3.rdl" />
    <Report Include="INF_ENV_PROD_ANA_4.rdl" />
    <Report Include="INF_ENV_PROD_ANA_5.rdl" />
    <Report Include="INF_ENV_PROD_ANA_5_SubReport.rdl" />
    <Report Include="INF_ENV_PROD_ANA_6.rdl" />
    <Report Include="INF_ENV_PROD_ANA_6_SubReport.rdl" />
    <Report Include="INF_ENV_PROD_ANA_7.rdl" />
    <Report Include="INF_ENV_PROD_ANA_7_SubReport.rdl" />
    <Report Include="INF_ENV_PROD_ANA_7_SubReportTurno.rdl" />
    <Report Include="INF_TRA_PROD_ALB_SAL_2.rdl" />
    <Report Include="INF_TRA_PROD_ALB_SAL_MAT.rdl" />
    <Report Include="PlantillaHorizontal.rdl" />
    <Report Include="PlantillaVertical.rdl" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath)\Reporting Services\Microsoft.ReportingServices.MSBuilder.targets" />
</Project>