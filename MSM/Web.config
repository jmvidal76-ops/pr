		<TipoEstadosOrden>
			<add key="Ready" value="1012" cambios="Planificada" color="A" />
			<add key="Processed" value="1011" cambios="Consolidando datos" color="Z" />

			<add key="InProgress" value="1014" cambios="Producción" color="V" />
			<add key="Terminated" value="1013" cambios="Cerrada" color="Z" />
		</TipoEstadosOrden>
		<!-- Tipos de estado de procedimiento POMV_ETRY_STAT-->
		<EstadoProcedimientos>
			<add key="Processed" value="1012" cambios="Procesada" color="N" />
			<add key="Ready" value="1010" cambios="Preparada" color="A" />
			<add key="Running" value="1011" cambios="Producción" color="P" />
		</EstadoProcedimientos>
		<NombreEspecificacionMaterial>
