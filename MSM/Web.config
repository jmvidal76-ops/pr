			<section name="EstadoProcedimientos" type="MSM.Utilidades.MSMSection" />
		</sectionGroup>
	</configSections>
	<common>
		<logging>
			<factoryAdapter type="Common.Logging.Log4Net.Log4NetLoggerFactoryAdapter, Common.Logging.Log4Net1212">
				<arg key="configType" value="INLINE" />
			</factoryAdapter>
		</logging>
	</common>
	<Envasado>
		<!-- Tipos de estado de máquina-->
		<EstadosMaquina>
			<add key="NoConectada" value="342" />
			<add key="Produccion" value="351" />
			<add key="Parada" value="343" />
		</EstadosMaquina>
		<!-- Tipos de estado de orden-->
		<EstadosOrden>
			<add key="Creada" keyReglaSIT="Creada" value="1002" color="BDBDBD" cambios="Cancelada" activa="false" pendiente="true" />
			<add key="Planificada" keyReglaSIT="Planificada" value="1007" cambios="Cancelada" color="00BFFF" activa="false" pendiente="true" />
			<add key="Cancelada" keyReglaSIT="Cancelada" value="1000" color="FF4000" activa="false" pendiente="false" />
			<add key="Iniciando" keyReglaSIT="Iniciando" value="1005" cambios="Pausada" color="E1F5A9" activa="true" pendiente="false" />
			<add key="Iniciar" value="1005" color="E1F5A9" />
			<add key="Pausada" keyReglaSIT="Pausada" value="1006" cambios="Finalizada" color="F7FE2E" activa="false" pendiente="true" />
			<add key="Cerrada" keyReglaSIT="Cerrada" value="1001" color="D0A9F5" activa="false" pendiente="false" />
			<add key="Finalizada" keyReglaSIT="Finalizada" value="1003" cambios="Cerrada" color="FAAC58" activa="false" pendiente="true" />
			<add key="Producción" keyReglaSIT="Producción" value="1009" cambios="Pausada" color="00FF00" activa="true" pendiente="false" />
		</EstadosOrden>
		<Pausa>
			<add key="Fin" value="FIN_PRODUCCION" keyReglaSIT="FIN_PRODUCCION"></add>
			<add key="Cambio" value="CAMBIO_PRODUCTO" keyReglaSIT="CAMBIO"></add>
			<add key="PausadaCambio" value="PAUSADA#CAMBIO" keyReglaSIT="PAUSADA#CAMBIO"></add>
			<add key="FinalizadaCambio" value="FINALIZADA#CAMBIO" keyReglaSIT="FINALIZADA#CAMBIO"></add>
			<add key="PausadaFinproduccion" value="PAUSADA#FIN_PRODUCCION" keyReglaSIT="PAUSADA#FIN_PRODUCCION"></add>
			<add key="FinalizadaFinproduccion" value="FINALIZADA#FIN_PRODUCCION" keyReglaSIT="FINALIZADA#FIN_PRODUCCION"></add>
		</Pausa>
		<!--Tipos arranque linea-->
		<ArranqueLinea>
			<add key="FinProduccion" value="FIN_PRODUCCION"></add>
			<add key="InicioProduccion" value="INICIO_PRODUCCION"></add>
		</ArranqueLinea>
	</Envasado>
