<?xml version="1.0" encoding="utf-8"?>

<!-- Para obtener más información sobre el uso de la transformación de web.config, visite http://go.microsoft.com/fwlink/?LinkId=125889 -->

<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <!--
    En el ejemplo siguiente, la transformación "SetAttributes" cambiará el valor de    "connectionString" para que solamente use "ReleaseSQLServer" cuando el localizador "Match"    encuentre un atributo "name" con el valor "MyDB".    <connectionStrings>     <add name="MyDB".        connectionString="Data Source=ReleaseSQLServer;Initial Catalog=MyReleaseDB;Integrated Security=True"        xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>    </connectionStrings>
  -->
  <appSettings>
    <add key="AVISO_CIERRE" value="true" xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <!-- Configuración de procesos de actualización-->
    <add key="CAMBIOS_ESTADO_ORDENES" value="true"  xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="CAMBIOS_ESTADO_MAQUINAS" value="true"  xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="CAMBIOS_TURNO_ACTUAL" value="true"  xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="ACT_DATOS_PRODUCCION" value="true"  xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="ACT_DATOS_PRODUCCION_MAQUINA" value="true"  xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>
    <add key="ACT_DATOS_PRODUCCION_ORDEN" value="true"  xdt:Transform="SetAttributes" xdt:Locator="Match(key)"/>

  </appSettings>
  
  <connectionStrings>
    <add name="sqlMES" connectionString="Server=10.2.20.201;database=MES_MSM_Fab;User Id=MES_MSM_user;Password=Idom2015;" providerName="System.Data.SqlClient"  xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
    <add name="sqlINTERSPC" connectionString="Server=10.2.20.201;database=MES_MSM_Fab;User Id=MES_MSM_user;Password=Idom2015;" providerName="System.Data.SqlClient"  xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
    <add name="sqlMESsa" connectionString="Server=10.2.20.201;database=MES_MSM_Fab;User Id=sa;Password=Msm2015;" providerName="System.Data.SqlClient"  xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
    <add name="MESEntities" connectionString="metadata=res://*/BBDD.Model.MESModel.csdl|res://*/BBDD.Model.MESModel.ssdl|res://*/BBDD.Model.MESModel.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=10.2.20.201;initial catalog=MES_MSM_Fab;user id=MES_MSM_user;password=Idom2015;MultipleActiveResultSets=True;App=EntityFramework&quot;" providerName="System.Data.EntityClient"  xdt:Transform="SetAttributes" xdt:Locator="Match(name)"/>
  </connectionStrings>
  <system.web>
    <compilation xdt:Transform="RemoveAttributes(debug)" />

  
    <!--
      En el ejemplo siguiente, la transformación "Replace" reemplazará toda la 
      sección <customErrors> del archivo web.config.
      Tenga en cuenta que, como solo hay una sección customErrors bajo el nodo 
      <system.web>, no es necesario usar el atributo "xdt:Locator".
      
      <customErrors defaultRedirect="GenericError.htm"
        mode="RemoteOnly" xdt:Transform="Replace">
        <error statusCode="500" redirect="InternalError.htm"/>
      </customErrors>
    -->
  </system.web>
</configuration>